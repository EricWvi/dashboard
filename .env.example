# PostgreSQL database connection
DASHBOARD_DB_HOST=postgres
DASHBOARD_DB_PORT=5432
DASHBOARD_DB_NAME=dashboard_test
DASHBOARD_DB_USERNAME=onlyquant
DASHBOARD_DB_PASSWORD=

# MinIO object store
DASHBOARD_MINIO_ENDPOINT=minio.onlyquant.top
DASHBOARD_MINIO_BUCKET=journal
DASHBOARD_MINIO_ACCESS_KEY_ID=dashboardtest
DASHBOARD_MINIO_SECRET_KEY=
DASHBOARD_MINIO_USE_SSL=true
DASHBOARD_MINIO_PRESIGN_EXPIRY=160h

# Logging (debug | info | warn | error)
DASHBOARD_LOG_LEVEL=info
