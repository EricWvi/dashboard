{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Flomo",
  "version": "0.1.0",
  "identifier": "top.onlyquant.flomo",
  "build": {
    "frontendDist": "../flomo",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:flomo",
    "beforeBuildCommand": "npm run build:flomo",
    "features": ["flomo"]
  },
  "app": {
    "windows": [
      {
        "title": "Flomo",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "flomo.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "schemes": ["flomo"]
    }
  }
}
