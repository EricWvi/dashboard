{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Dashboard",
  "version": "0.1.0",
  "identifier": "top.onlyquant.dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:dashboard",
    "beforeBuildCommand": "npm run build:dashboard"
  },
  "app": {
    "windows": [
      {
        "title": "Dashboard",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/android"
    ]
  },
  "plugins": {
    "deep-link": {
      "schemes": ["dashboard"]
    }
  }
}
