{
  "productName": "Flomo",
  "version": "0.1.0",
  "identifier": "top.onlyquant.flomo",
  "build": {
    "beforeDevCommand": "npm run dev:flomo",
    "devUrl": "http://localhost:5273",
    "beforeBuildCommand": "npm run build:flomo",
    "frontendDist": "../flomo"
  },
  "app": {
    "windows": [
      {
        "title": "Flomo",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
